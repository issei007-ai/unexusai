# ─────────────────────────────────────────────────────────────────────────────
# LEAD PIPELINE — copy to .env.local (local) or set in Vercel → Project → Settings
# → Environment Variables (production).
#
# Each channel switches ON automatically when its variables below are filled in,
# and stays OFF when they're blank. Set only the ones you want.
#
# Optional master switch: list the channels you want active, comma-separated.
# Leave it blank/unset to let every configured channel run.
#   LEAD_CHANNELS=email,whatsapp,database
# ─────────────────────────────────────────────────────────────────────────────
LEAD_CHANNELS=

# ── Email (Resend — https://resend.com) ──────────────────────────────────────
# Create an API key, then verify a sending domain (or use Resend's onboarding
# domain "onboarding@resend.dev" for testing).
RESEND_API_KEY=
LEAD_EMAIL_FROM=DigiExperts <leads@yourdomain.com>
LEAD_EMAIL_TO=you@yourdomain.com            # comma-separate for multiple inboxes

# ── WhatsApp (Meta WhatsApp Cloud API) ───────────────────────────────────────
# From developers.facebook.com → your app → WhatsApp → API Setup.
# WHATSAPP_TO is the number that RECEIVES the lead alert, digits only w/ country
# code, e.g. 447700900123. Free-form text only delivers inside the 24h window;
# for always-on alerts use an approved template.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_TO=
# For always-on alerts (outside the 24h window), use an approved template.
# Leave WHATSAPP_TEMPLATE blank to send free-form text instead (testing only).
# The template must have 4 body variables: {{1}} type {{2}} who {{3}} details
# {{4}} source. Exact template text is in LEADS.md.
# WHATSAPP_TEMPLATE=new_lead
# WHATSAPP_TEMPLATE_LANG=en
# WHATSAPP_API_VERSION=v21.0                # optional override

# ── Database (Neon — serverless Postgres) ────────────────────────────────────
# Create a NEW project at console.neon.tech, then copy the *pooled* connection
# string (Connection Details → "Pooled connection", host contains "-pooler").
# The leads table is created automatically on the first submission.
NEON_DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# ── Analytics (Google Analytics 4) ───────────────────────────────────────────
# Measurement ID from analytics.google.com → Admin → Data Streams → your web
# stream. Leave blank to disable analytics entirely (no gtag script is loaded).
# NEXT_PUBLIC_ is required — this value is read in the browser, and it is public
# by design (it appears in page source on every GA-tracked site).
NEXT_PUBLIC_GA_ID=

# ── Admin (lead viewer at /admin/leads) ──────────────────────────────────────
# Set a password to unlock the protected leads dashboard. Leave blank to keep
# the admin area disabled entirely.
ADMIN_PASSWORD=
